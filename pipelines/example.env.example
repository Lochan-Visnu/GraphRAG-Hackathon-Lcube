# --- Google Gemini API ---
# This powers your "Gen AI" logic for all three pipelines
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE

# --- TigerGraph Connection (TG) ---
# Found in your Savanna dashboard at tgcloud.io
TG_HOST=https://your-subdomain.aws.connect.tigergraph.io
TG_USERNAME=tigergraph
TG_PASSWORD=YOUR_DATABASE_PASSWORD_HERE
TG_SECRET_KEY=YOUR_REST_API_SECRET_HERE

# --- Graph Specifics ---
# The name you gave your graph in TigerGraph (default is usually MedicalGraphRAG)

TG_GRAPH_NAME=MyGraph
# 🧬 MEDIC-AI Environment Configuration
# Replace the value below with your actual Google Gemini API Key

GEMINI_API_KEY=your_api_key_here
