{
    "db_config": {
        "hostname": "HOST_URL",
        "restppPort": "443",
        "gsPort": "443",
        "graphname": "MedicalGraphRAG",
        "gsqlSecret": "SECRET_KEY",
        "apiToken": "TOKENS",
        "getToken": false,
        "default_timeout": 300,
        "default_mem_threshold": 5000,
        "default_thread_limit": 8
    },
    "graphrag_config": {
        "reuse_embedding": false,
        "ecc": "http://graphrag-ecc:8001",
        "chat_history_api": "http://chat-history:8002",
        "chunker": "semantic",
        "extractor": "llm",
        "top_k": 5,
        "num_hops": 2
    },
    "llm_config": {
        "embedding_service": {
            "embedding_model_service": "genai",
            "model_name": "models/gemini-embedding-exp-03-07",
            "dimensions": 1536,
            "authentication_configuration": {
                "GOOGLE_API_KEY": "YOUR_API_KEY"
            }
        },
        "completion_service": {
            "llm_service": "genai",
            "llm_model": "gemini-2.5-flash-lite",
            "authentication_configuration": {
                "GOOGLE_API_KEY": "YOR_API_KEY"
            },
            "model_kwargs": { "temperature": 0 },
            "prompt_path": "./common/prompts/google_gemini/"
        }
    },
    "chat_config": {
        "apiPort": "8002",
        "dbPath": "chats.db",
        "dbLogPath": "db.log",
        "logPath": "requestLogs.jsonl",
        "conversationAccessRoles": ["superuser", "globaldesigner"]
    }
}
